                    <button class="checkout-btn primary" id="miniCartCheckoutBtn" onclick="navigate('checkout')">Checkout</button>
                    <button class="view-cart-btn secondary" id="miniCartViewCartBtn" onclick="navigate('cart')">View cart</button>
                </div>
            </div>
        </aside>

        <!-- Overlay -->
        <div class="overlay" id="overlay"></div>

    </div>
<!-- BOTTOM NAV (Mobile Only) -->
    <div class="bottom-nav">
        <div class="bnav-item active" id="bnav-home" data-target="home" onclick="navigate('home')">
            <i class="fas fa-home"></i><span>Home</span>
