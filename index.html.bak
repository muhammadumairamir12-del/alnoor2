                                <span>to</span>
                                <input type="number" id="maxPriceInput" aria-label="Maximum Price" value="${maxPrice}" placeholder="Max">
                                <button class="primary" id="applyPriceFilter" aria-label="Apply Price Filter">Apply</button>
