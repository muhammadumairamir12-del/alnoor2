        <div class="bnav-item" id="bnav-search" data-target="search" onclick="toggleSearch()">
            <i class="fas fa-search"></i><span>Search</span>
        </div>
        <div class="bnav-item" id="bnav-products" data-target="products" onclick="navigate('products')">
            <i class="fas fa-th-large"></i><span>Collection</span>
        </div>
        <div class="bnav-item" id="bnav-account" data-target="account" onclick="navigate('account')">
            <i class="fas fa-user"></i><span>Account</span>
        </div>
